PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Optional Autonomous Database persistence.
ADB_USER=ADMIN
ADB_PASSWORD=replace-me
ADB_CONNECT_STRING=replace-me_high

# Populated by Terraform/cloud-init on OCI VMs.
API_GATEWAY_NAME=local-api-gateway
LOAD_BALANCER_NAME=local-load-balancer
OCI_STREAM_OCID=
OCI_BUCKET_NAME=
OCI_REGION=eu-stockholm-1
REDIS_HOST=
REDIS_PORT=6379
REDIS_TLS=true
LIVE_PLAYER_TTL_SECONDS=60

# Optional external copilot endpoint. Without this, the app uses deterministic demo insights.
OCI_GENAI_ENDPOINT=
OCI_GENAI_BEARER_TOKEN=
